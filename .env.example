# =============================================================================
# Safe Trading — Variáveis de Ambiente
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: copy .env.example .env
#   2. Preencha com seus valores reais
#   3. NUNCA commite o arquivo .env no git (já está no .gitignore)
# =============================================================================

# --- Supabase (banco de dados cloud) ---
# Obtenha em: https://supabase.com > seu projeto > Settings > API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...

# --- Autenticação do Dashboard ---
# Protege o dashboard com usuário/senha via HTTP Basic Auth
DASHBOARD_USER=andre
DASHBOARD_PASSWORD=sua_senha_aqui

# --- Porta do servidor ---
# Railway injeta PORT automaticamente em produção
# Em desenvolvimento local, usa 8050 como padrão
PORT=8050

# --- Chaves da API da Binance (opcional por enquanto) ---
# Para paper trading usamos apenas a API pública (sem chaves)
# Necessário apenas para trading real no futuro
BINANCE_API_KEY=sua_api_key_aqui
BINANCE_SECRET=seu_secret_aqui
BINANCE_TESTNET=true
